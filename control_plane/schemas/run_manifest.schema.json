{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "run_manifest",
  "type": "object",
  "required": [
    "run_id",
    "question",
    "model",
    "dataset",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "question": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hardware": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "queued",
        "leased",
        "running",
        "retryable",
        "blocked",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
