{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "evaluation_registry",
  "type": "object",
  "required": [
    "evaluations"
  ],
  "properties": {
    "evaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evaluation_id",
          "target_type",
          "target_id",
          "evaluator",
          "status"
        ],
        "properties": {
          "evaluation_id": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "evaluator": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warn"
            ]
          },
          "score": {
            "type": [
              "number",
              "null"
            ]
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "checks": {
            "type": "array"
          }
        }
      }
    }
  }
}
