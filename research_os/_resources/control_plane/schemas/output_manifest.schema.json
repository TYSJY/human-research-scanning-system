{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "output_manifest",
  "type": "object",
  "required": [
    "run_id",
    "files",
    "missing"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "size_bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "kind": {
            "type": [
              "string",
              "null"
            ]
          },
          "required": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "promote_to_artifact_registry": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "size_bytes": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "provenance": {
            "type": "object"
          }
        }
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
